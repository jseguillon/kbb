# kbb Game Kubernetes Deployment Configuration
# Copy this to .env and fill in your values

# Docker registry for GitHub Container Registry
DOCKER_REGISTRY?=ghcr.io
GITHUB_USER?=your-github-username
FRONTEND_IMAGE_NAME?=kbb-frontend
MIDDLEWARE_IMAGE_NAME?=k8s-middleware

# Full image references
FRONTEND_IMAGE=${DOCKER_REGISTRY}/${GITHUB_USER}/${FRONTEND_IMAGE_NAME}
MIDDLEWARE_IMAGE=${DOCKER_REGISTRY}/${GITHUB_USER}/${MIDDLEWARE_IMAGE_NAME}

# Namespace for deployment
K8S_NAMESPACE?=default

# Ingress host (for external access)
INGRESS_HOST?=kbb.local

# Middleware port
MIDDLEWARE_PORT?=3001

# Frontend port
FRONTEND_PORT?=80

# Kubeconfig path (for local development)
KUBECONFIG?=~/.kube/config
